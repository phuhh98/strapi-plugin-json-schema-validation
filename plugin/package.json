{
  "version": "0.1.0",
  "keywords": [
    "strapi",
    "plugin",
    "json",
    "schema",
    "validation",
    "custom field"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "tsc -p admin/tsconfig.json --noEmit",
    "test:ts:back": "tsc -p server/tsconfig.json --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "jsonschema": "^1.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/sdk-plugin": "^6.1.0",
    "@strapi/strapi": "^5.46.0",
    "@strapi/typescript-utils": "^5.46.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.39.4",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "lucide-react": "^1.16.0",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/sdk-plugin": "^6.1.0",
    "@strapi/strapi": "^5.46.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.4.1"
  },
  "strapi": {
    "kind": "plugin",
    "name": "strapi-plugin-json-schema-validation",
    "displayName": "JSON Schema validation",
    "description": "Provide JSON Schema validation custom field and utilities"
  },
  "name": "strapi-plugin-json-schema-validation",
  "description": "Provide JSON Schema validation custom field and utilities",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/phuhh98/strapi-plugin-json-schema-validation.git"
  },
  "bugs": {
    "url": "https://github.com/phuhh98/strapi-plugin-json-schema-validation/issues"
  },
  "homepage": "https://github.com/phuhh98/strapi-plugin-json-schema-validation#readme",
  "author": "phuhh98 <phuhh98@gmail.com>"
}
